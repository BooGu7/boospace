---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import type { SiteLocale } from "@utils/locale-utils";

interface Props {
	locale: SiteLocale;
}

const { locale } = Astro.props;
---

<div class="card-base px-8 md:px-10 py-10 md:py-12 text-center rounded-[var(--radius-large)]">
	<div class="inline-flex items-center justify-center rounded-full px-4 py-1.5 text-[0.7rem] font-semibold tracking-[0.18em] uppercase bg-[var(--btn-plain-bg-hover)] text-[var(--primary)] mb-4">
		{i18n(locale, I18nKey.language)}
	</div>
	<h2 class="text-2xl md:text-3xl font-bold text-90 mb-3">
		{i18n(locale, I18nKey.noPostsTitle)}
	</h2>
	<p class="text-50 max-w-xl mx-auto">
		{i18n(locale, I18nKey.noPostsDescription)}
	</p>
</div>
