---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { getTranslatedPostSlug } from "@utils/content-utils";
import {
	getLocaleFromPathname,
	type SiteLocale,
	stripLocaleFromPathname,
	withLocale,
} from "@utils/locale-utils";
import { getPostUrlBySlug } from "@utils/url-utils";

interface Props {
	locale?: SiteLocale;
	variant?: "desktop" | "mobile";
}

const { variant = "desktop" } = Astro.props;
const locale = Astro.props.locale || getLocaleFromPathname(Astro.url.pathname);
const pathname = Astro.url.pathname;
const strippedPath = stripLocaleFromPathname(pathname);

async function resolveLocaleHref(targetLocale: SiteLocale) {
	if (targetLocale === locale) {
		return Astro.url.pathname + Astro.url.search;
	}

	if (strippedPath.startsWith("/posts/")) {
		const slug = strippedPath.replace(/^\/posts\/|\/$/g, "");
		const translatedSlug = await getTranslatedPostSlug(slug, targetLocale);
		if (!translatedSlug) {
			return withLocale("/archive/", targetLocale);
		}
		return getPostUrlBySlug(translatedSlug, targetLocale);
	}

	const staticPageMap = new Set([
		"/",
		"/about/",
		"/archive/",
		"/privacy-policy/",
		"/terms-of-service/",
		"/login/",
	]);

	if (staticPageMap.has(strippedPath)) {
		const suffix = Astro.url.search || "";
		return `${withLocale(strippedPath, targetLocale)}${suffix}`;
	}

	return withLocale("/", targetLocale);
}

const viHref = await resolveLocaleHref("vi");
const enHref = await resolveLocaleHref("en");
const pillClass =
	variant === "mobile"
		? "mt-1 mb-2 rounded-2xl border border-black/10 dark:border-white/10 bg-black/[0.03] dark:bg-white/[0.04] p-1"
		: "hidden md:flex rounded-2xl border border-black/10 dark:border-white/10 bg-black/[0.03] dark:bg-white/[0.04] p-1 mx-2";
---

<div
	class:list={[
		"items-center gap-1 transition",
		pillClass,
		variant === "mobile" ? "flex" : "",
	]}
	aria-label={i18n(locale, I18nKey.language)}
>
	<a
		href={viHref}
		class:list={[
			"rounded-xl px-3.5 h-9 inline-flex items-center justify-center text-sm font-semibold tracking-[0.08em] transition active:scale-95",
			locale === "vi"
				? "bg-[var(--primary)] text-white dark:text-black/80 shadow-[0_10px_30px_-18px_var(--primary)]"
				: "text-black/55 dark:text-white/60 hover:bg-white/70 dark:hover:bg-white/8 hover:text-black/80 dark:hover:text-white/85",
		]}
		aria-label={i18n(locale, I18nKey.languageVietnamese)}
	>
		{i18n(locale, I18nKey.languageVietnamese)}
	</a>
	<a
		href={enHref}
		class:list={[
			"rounded-xl px-3.5 h-9 inline-flex items-center justify-center text-sm font-semibold tracking-[0.08em] transition active:scale-95",
			locale === "en"
				? "bg-[var(--primary)] text-white dark:text-black/80 shadow-[0_10px_30px_-18px_var(--primary)]"
				: "text-black/55 dark:text-white/60 hover:bg-white/70 dark:hover:bg-white/8 hover:text-black/80 dark:hover:text-white/85",
		]}
		aria-label={i18n(locale, I18nKey.languageEnglish)}
	>
		{i18n(locale, I18nKey.languageEnglish)}
	</a>
</div>
