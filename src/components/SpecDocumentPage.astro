---
import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";

interface Props {
	entryId: string;
	title: string;
	description?: string;
	lang?: string;
	canonicalPath?: string;
	noindex?: boolean;
	alternates?: Partial<Record<"vi" | "en", string>>;
}

const {
	entryId,
	title,
	description = title,
	lang,
	canonicalPath,
	noindex = false,
	alternates,
} = Astro.props;

const entry = await getEntry("spec", entryId);

if (!entry) {
	throw new Error(`Spec page content not found: ${entryId}`);
}

const { Content, headings } = await render(entry);
---

<MainGridLayout
	title={title}
	description={description}
	lang={lang}
	headings={headings}
	canonicalPath={canonicalPath}
	alternates={alternates}
>
	{noindex && <meta slot="head" name="robots" content="noindex,follow" />}

	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
			<Markdown class="mt-2" pagefindBody={!noindex}>
				<Content />
			</Markdown>
		</div>
	</div>
</MainGridLayout>
