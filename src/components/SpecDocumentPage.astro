---
import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";

interface Props {
	entryId: string;
	title: string;
	description?: string;
	lang?: string;
	canonicalPath?: string;
	noindex?: boolean;
}

const {
	entryId,
	title,
	description = title,
	lang,
	canonicalPath,
	noindex = false,
} = Astro.props;

const entry = await getEntry("spec", entryId);

if (!entry) {
	throw new Error(`Spec page content not found: ${entryId}`);
}

const { Content, headings } = await render(entry);
const canonicalUrl =
	canonicalPath && Astro.site
		? new URL(canonicalPath, Astro.site).toString()
		: undefined;
---

<MainGridLayout
	title={title}
	description={description}
	lang={lang}
	headings={headings}
>
	{canonicalUrl && (
		<link slot="head" rel="canonical" href={canonicalUrl} />
	)}
	{noindex && <meta slot="head" name="robots" content="noindex,follow" />}

	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
			<Markdown class="mt-2" pagefindBody={!noindex}>
				<Content />
			</Markdown>
		</div>
	</div>
</MainGridLayout>
