---
import { render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getLocaleFromPathname } from "@utils/locale-utils";
import { getLocalizedSpecEntry } from "@utils/spec-utils";

interface Props {
	entryId?: string;
	entryBaseName?: string;
	title: string;
	description?: string;
	lang?: string;
	canonicalPath?: string;
	noindex?: boolean;
	alternates?: Partial<Record<"vi" | "en", string>>;
}

const {
	entryId,
	entryBaseName,
	title,
	description = title,
	lang,
	canonicalPath,
	noindex = false,
	alternates,
} = Astro.props;

const resolvedLocale = getLocaleFromPathname(Astro.url.pathname);
const entry =
	entryId
		? await getLocalizedSpecEntry(entryId, resolvedLocale)
		: entryBaseName
			? await getLocalizedSpecEntry(entryBaseName, resolvedLocale)
			: undefined;

if (!entry) {
	throw new Error(
		`Spec page content not found: ${entryBaseName || entryId || "unknown"}`,
	);
}

const { Content, headings } = await render(entry);
---

<MainGridLayout
	title={title}
	description={description}
	lang={lang}
	headings={headings}
	canonicalPath={canonicalPath}
	alternates={alternates}
>
	{noindex && <meta slot="head" name="robots" content="noindex,follow" />}

	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
			<Markdown class="mt-2" pagefindBody={!noindex}>
				<Content />
			</Markdown>
		</div>
	</div>
</MainGridLayout>
