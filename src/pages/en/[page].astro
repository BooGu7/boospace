---
import Pagination from "@components/control/Pagination.astro";
import PostPage from "@components/PostPage.astro";
import { PAGE_SIZE } from "@constants/constants";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPosts } from "@utils/content-utils";
import type { GetStaticPaths, Page } from "astro";

export const getStaticPaths = (async () => {
	const allBlogPosts = await getSortedPosts("en");
	const lastPage = Math.ceil(allBlogPosts.length / PAGE_SIZE);

	return Array.from({ length: Math.max(0, lastPage - 1) }, (_, index) => {
		const currentPage = index + 2;
		const start = (currentPage - 1) * PAGE_SIZE;
		const page = {
			data: allBlogPosts.slice(start, start + PAGE_SIZE),
			currentPage,
			lastPage,
			url: {
				prev: currentPage === 2 ? "/en/" : `/en/${currentPage - 1}/`,
				next: currentPage < lastPage ? `/en/${currentPage + 1}/` : undefined,
			},
		} as Page;

		return {
			params: { page: String(currentPage) },
			props: { page },
		};
	});
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<MainGridLayout lang="en" alternates={{ vi: "/vn/", en: "/en/" }}>
	<PostPage page={page}></PostPage>
	<Pagination
		class="mx-auto onload-animation"
		page={page}
		style={`animation-delay: calc(var(--content-delay) + ${page.data.length * 50}ms)`}
	></Pagination>
</MainGridLayout>
