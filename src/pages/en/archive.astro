---
import ArchivePanel from "@components/ArchivePanel.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsList } from "@utils/content-utils";

const sortedPostsList = await getSortedPostsList("en");
---

<MainGridLayout title={i18n("en", I18nKey.archive)} lang="en" alternates={{ vi: "/archive/", en: "/en/archive/" }}>
	<ArchivePanel locale="en" sortedPosts={sortedPostsList} client:only="svelte"></ArchivePanel>
</MainGridLayout>
