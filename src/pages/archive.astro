---
export const prerender = true;
import ArchivePanel from "@components/ArchivePanel.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsList } from "../utils/content-utils";
import { getLocaleFromPathname } from "../utils/locale-utils";

const locale = getLocaleFromPathname(Astro.url.pathname);
const sortedPostsList = await getSortedPostsList(locale);
---

<MainGridLayout title={i18n(locale, I18nKey.archive)} lang={locale}>
    <ArchivePanel locale={locale} sortedPosts={sortedPostsList} client:only="svelte"></ArchivePanel>
</MainGridLayout>

